# Build output
[Bb]in/
[Oo]bj/

# Neural-net training artifacts (regenerable, large). The shipped policy weights
# (weights.bin) and the documented supervised baseline (weights_supervised.bin)
# are intentionally NOT ignored — they are embedded resources / reference points.
src/AI/Santase.AI.ClaudePlayer/Neural/checkpoints/
**/checkpoints/
training_*.bin
weights_smoke.bin
*.training.bin

# Local distillation-pipeline scratch (datasets, checkpoints, run logs — large, regenerable)
tools/NeuralTrainer/_scratch/

# EngineBench paired-comparison snapshots (built baseline/variant binaries, regenerable)
tools/EngineBench/_bench/

# Local Claude Code agent state
.claude/

# Android release signing — NEVER commit the upload keystore or its passwords.
# Losing this file (or its passwords) means you can no longer push updates under
# the same upload key; keep an off-machine backup. See src/UI/Santase.UI/PLAYSTORE.md.
*.keystore
*.jks
signing.user.props
