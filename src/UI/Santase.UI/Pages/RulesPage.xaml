<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Santase.UI.Localization"
             x:Class="Santase.UI.Pages.RulesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource FeltDark}">

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.3" Radius="0.95">
                <GradientStop Color="{StaticResource FeltLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource FeltMid}" Offset="0.55" />
                <GradientStop Color="{StaticResource FeltDark}" Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="24,20,24,32"
                                 Spacing="14"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Start"
                                 MaximumWidthRequest="540">

                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="‹"
                            Clicked="OnBack"
                            HeightRequest="36"
                            WidthRequest="40"
                            Padding="0,0,0,4"
                            FontSize="22"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            BackgroundColor="#26000000"
                            BorderColor="#3FE2B864"
                            BorderWidth="1"
                            TextColor="{StaticResource GoldHighlight}" />
                    <Label Grid.Column="1"
                           Text="{loc:Tr Rules_Title}"
                           FontSize="24"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{StaticResource GoldHighlight}" />
                </Grid>

                <Label Text="{loc:Tr Rules_Intro}"
                       FontSize="14"
                       TextColor="#EDE3C3"
                       LineHeight="1.25" />

                <VerticalStackLayout x:Name="SectionsHost" Spacing="12" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
