<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:game="clr-namespace:Santase.UI.Game"
             xmlns:loc="clr-namespace:Santase.UI.Localization"
             x:Class="Santase.UI.Pages.StartPage"
             x:Name="ThePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource FeltDark}">

    <Grid>
        <!-- Felt background gradient -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.35" Radius="0.95">
                <GradientStop Color="{StaticResource FeltLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource FeltMid}" Offset="0.55" />
                <GradientStop Color="{StaticResource FeltDark}" Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="24,20,24,32"
                                 Spacing="18"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Start"
                                 MaximumWidthRequest="540">

                <!-- Top bar: language toggle + settings -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Button Grid.Column="1"
                            x:Name="LangButton"
                            Clicked="OnToggleLanguage"
                            HeightRequest="34"
                            MinimumWidthRequest="92"
                            Padding="14,0"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="17"
                            BackgroundColor="#26000000"
                            BorderColor="{StaticResource GoldAccent}"
                            BorderWidth="1"
                            TextColor="{StaticResource GoldHighlight}" />
                    <Button Grid.Column="2"
                            Text="⚙"
                            Clicked="OnOpenSettings"
                            HeightRequest="34"
                            WidthRequest="40"
                            Padding="0"
                            FontSize="16"
                            CornerRadius="17"
                            BackgroundColor="#26000000"
                            BorderColor="{StaticResource GoldAccent}"
                            BorderWidth="1"
                            TextColor="{StaticResource GoldHighlight}" />
                </Grid>

                <!-- Title block. Composed of three no-wrap labels (small suits flanking the
                     wordmark) so it always stays on one line, even on narrow phones. -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="♠ ♥"
                               FontSize="16"
                               LineBreakMode="NoWrap"
                               VerticalOptions="Center"
                               TextColor="{StaticResource GoldAccent}" />
                        <Label Text="SANTASE"
                               FontSize="30"
                               FontAttributes="Bold"
                               CharacterSpacing="3"
                               LineBreakMode="NoWrap"
                               VerticalOptions="Center"
                               TextColor="{StaticResource GoldHighlight}" />
                        <Label Text="♦ ♣"
                               FontSize="16"
                               LineBreakMode="NoWrap"
                               VerticalOptions="Center"
                               TextColor="{StaticResource GoldAccent}" />
                    </HorizontalStackLayout>
                    <Label Text="{loc:Tr Start_Subtitle}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="#D9CFAE"
                           CharacterSpacing="2" />
                </VerticalStackLayout>

                <!-- Player rating card (tap → statistics) -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="#26000000"
                        Padding="20,14"
                        HorizontalOptions="Fill">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOpenStatistics" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                            <Label x:Name="RatingCaptionLabel"
                                   FontSize="11"
                                   CharacterSpacing="2"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource GoldAccent}" />
                            <Label x:Name="RatingLabel"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource GoldHighlight}" />
                            <Label x:Name="RecordLabel"
                                   FontSize="11"
                                   HorizontalOptions="Center"
                                   TextColor="#B9C7B0" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Label Text="📊"
                                   FontSize="18"
                                   HorizontalOptions="Center" />
                            <Label Text="{loc:Tr Start_Statistics}"
                                   FontSize="10"
                                   TextColor="#D9CFAE" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- How to play -->
                <Button Text="{loc:Tr Start_HowToPlay}"
                        Clicked="OnOpenRules"
                        HeightRequest="44"
                        FontSize="14"
                        CornerRadius="12"
                        BackgroundColor="#22000000"
                        BorderColor="#3FE2B864"
                        BorderWidth="1"
                        TextColor="#EDE3C3" />

                <!-- Your name -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Tr Start_YourName}"
                           FontSize="11"
                           TextColor="{StaticResource GoldAccent}"
                           CharacterSpacing="3" />
                    <Entry x:Name="FirstPlayerEntry"
                           Placeholder="{loc:Tr Start_Player1}"
                           TextColor="White"
                           PlaceholderColor="#7FFFFFFF"
                           BackgroundColor="#22000000"
                           Unfocused="OnPlayerNameChanged" />
                </VerticalStackLayout>

                <!-- Opponent list -->
                <Label Text="{loc:Tr Start_ChooseOpponent}"
                       FontSize="11"
                       TextColor="{StaticResource GoldAccent}"
                       CharacterSpacing="3" />

                <VerticalStackLayout x:Name="OpponentList" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="game:AiOpponent">
                            <Border StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    BackgroundColor="#26000000"
                                    Padding="14,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference ThePage}, Path=SelectOpponentCommand}"
                                                          CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <!-- Avatar -->
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 23"
                                            StrokeThickness="1"
                                            Stroke="#59E2B864"
                                            BackgroundColor="#1F000000"
                                            WidthRequest="46"
                                            HeightRequest="46"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding Avatar}"
                                               FontSize="22"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <!-- Name, difficulty, tagline, personal record -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="17"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   TextColor="White" />
                                            <Border StrokeShape="RoundRectangle 7"
                                                    StrokeThickness="0"
                                                    BackgroundColor="#26FFFFFF"
                                                    Padding="7,2"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding DifficultyLabel}"
                                                       FontSize="10"
                                                       TextColor="#E2D9B8" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Tagline}"
                                               FontSize="12"
                                               TextColor="#C7D2BD" />
                                        <Label Text="{Binding RecordText}"
                                               IsVisible="{Binding HasRecord}"
                                               FontSize="11"
                                               TextColor="{StaticResource GoldHighlight}" />
                                    </VerticalStackLayout>
                                    <!-- ELO + stars -->
                                    <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                                        <Border StrokeShape="RoundRectangle 9"
                                                StrokeThickness="0"
                                                Padding="12,5"
                                                HorizontalOptions="Center"
                                                BackgroundColor="{StaticResource GoldHighlight}">
                                            <Label Text="{Binding EloText}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="#1A1006" />
                                        </Border>
                                        <Label Text="{Binding DifficultyStars}"
                                               FontSize="11"
                                               HorizontalOptions="Center"
                                               TextColor="{StaticResource GoldHighlight}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Recent games -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                    <Label Grid.Column="0"
                           Text="{loc:Tr Start_RecentGames}"
                           FontSize="11"
                           TextColor="{StaticResource GoldAccent}"
                           CharacterSpacing="3"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           x:Name="SeeAllLabel"
                           FontSize="12"
                           TextColor="#D9CFAE"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenStatistics" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Label x:Name="NoHistoryLabel"
                       Text="{loc:Tr Start_NoHistory}"
                       FontSize="12"
                       TextColor="#99FFFFFF" />

                <VerticalStackLayout x:Name="HistoryList" Spacing="6" />

                <BoxView HeightRequest="1" Color="#3FE2B864" Margin="0,6" />

                <!-- Hot-seat -->
                <Border StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        BackgroundColor="#22000000"
                        Padding="16,12">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Tr Start_HotSeatTitle}"
                               FontSize="11"
                               TextColor="{StaticResource GoldAccent}"
                               CharacterSpacing="3" />
                        <Label Text="{loc:Tr Start_HotSeatHint}"
                               FontSize="12"
                               TextColor="#C7D2BD" />
                        <Entry x:Name="SecondPlayerEntry"
                               Placeholder="{loc:Tr Start_Player2}"
                               TextColor="White"
                               PlaceholderColor="#7FFFFFFF"
                               BackgroundColor="#22000000" />
                        <Button Text="{loc:Tr Start_HotSeat}"
                                Clicked="OnPlayHotSeat"
                                BackgroundColor="#33FFFFFF"
                                BorderColor="{StaticResource GoldAccent}"
                                BorderWidth="1"
                                TextColor="White"
                                FontSize="16"
                                HeightRequest="50"
                                CornerRadius="12" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="v1.1 · github.com/NikolayIT/SantaseGameEngine"
                       FontSize="10"
                       HorizontalOptions="Center"
                       TextColor="#80FFFFFF"
                       Margin="0,8,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
