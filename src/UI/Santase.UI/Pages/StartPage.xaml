<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:game="clr-namespace:Santase.UI.Game"
             xmlns:loc="clr-namespace:Santase.UI.Localization"
             x:Class="Santase.UI.Pages.StartPage"
             x:Name="ThePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource FeltDark}">

    <Grid>
        <!-- Felt background gradient -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.35" Radius="0.95">
                <GradientStop Color="{StaticResource FeltLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource FeltMid}" Offset="0.55" />
                <GradientStop Color="{StaticResource FeltDark}" Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="24,40,24,32"
                                 Spacing="18"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Start"
                                 MaximumWidthRequest="540">

                <!-- Language toggle (top-right) -->
                <Button x:Name="LangButton"
                        Clicked="OnToggleLanguage"
                        HorizontalOptions="End"
                        HeightRequest="34"
                        MinimumWidthRequest="92"
                        Padding="14,0"
                        FontSize="13"
                        FontAttributes="Bold"
                        CornerRadius="17"
                        BackgroundColor="#26000000"
                        BorderColor="{StaticResource GoldAccent}"
                        BorderWidth="1"
                        TextColor="{StaticResource GoldHighlight}" />

                <!-- Title block -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="♠ ♥  SANTASE  ♦ ♣"
                           FontSize="36"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource GoldHighlight}" />
                    <Label x:Name="SubtitleLabel"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="#D9CFAE"
                           CharacterSpacing="2" />
                </VerticalStackLayout>

                <!-- Player rating badge -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="#26000000"
                        Padding="20,14"
                        HorizontalOptions="Center"
                        MinimumWidthRequest="240">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label x:Name="RatingCaptionLabel"
                               FontSize="11"
                               CharacterSpacing="2"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource GoldAccent}" />
                        <Label x:Name="RatingLabel"
                               FontSize="30"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource GoldHighlight}" />
                        <Label x:Name="RecordLabel"
                               FontSize="11"
                               HorizontalOptions="Center"
                               TextColor="#B9C7B0" />
                    </VerticalStackLayout>
                </Border>

                <!-- Your name -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                    <Label Grid.Column="0"
                           x:Name="YouLabel"
                           VerticalOptions="Center"
                           TextColor="White"
                           FontSize="14" />
                    <Entry Grid.Column="1"
                           x:Name="FirstPlayerEntry"
                           TextColor="White"
                           PlaceholderColor="#7FFFFFFF"
                           BackgroundColor="#22000000" />
                </Grid>

                <!-- Opponent list -->
                <Label x:Name="ChooseOpponentLabel"
                       FontSize="11"
                       TextColor="{StaticResource GoldAccent}"
                       CharacterSpacing="3" />

                <VerticalStackLayout x:Name="OpponentList" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="game:AiOpponent">
                            <Border StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    BackgroundColor="#26000000"
                                    Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference ThePage}, Path=SelectOpponentCommand}"
                                                          CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding DisplayName}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        <Label Text="{Binding Tagline}"
                                               FontSize="12"
                                               TextColor="#C7D2BD" />
                                        <Label Text="{Binding DifficultyStars}"
                                               FontSize="13"
                                               TextColor="{StaticResource GoldHighlight}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            StrokeShape="RoundRectangle 9"
                                            StrokeThickness="0"
                                            Padding="12,6"
                                            VerticalOptions="Center"
                                            BackgroundColor="{StaticResource GoldHighlight}">
                                        <Label Text="{Binding EloText}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#1A1006" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Recent games -->
                <Label x:Name="RecentGamesLabel"
                       FontSize="11"
                       TextColor="{StaticResource GoldAccent}"
                       CharacterSpacing="3"
                       Margin="0,6,0,0" />

                <Label x:Name="NoHistoryLabel"
                       FontSize="12"
                       TextColor="#99FFFFFF" />

                <VerticalStackLayout x:Name="HistoryList" Spacing="6" />

                <BoxView HeightRequest="1" Color="#3FE2B864" Margin="0,6" />

                <!-- Hot-seat -->
                <Border StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        BackgroundColor="#22000000"
                        Padding="16,12">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   x:Name="P2Label"
                                   VerticalOptions="Center"
                                   TextColor="White"
                                   FontSize="14" />
                            <Entry Grid.Column="1"
                                   x:Name="SecondPlayerEntry"
                                   TextColor="White"
                                   PlaceholderColor="#7FFFFFFF"
                                   BackgroundColor="#22000000" />
                        </Grid>
                        <Button x:Name="HotSeatButton"
                                Clicked="OnPlayHotSeat"
                                BackgroundColor="#33FFFFFF"
                                BorderColor="{StaticResource GoldAccent}"
                                BorderWidth="1"
                                TextColor="White"
                                FontSize="16"
                                HeightRequest="50"
                                CornerRadius="12" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="v1.0 · github.com/NikolayIT/SantaseGameEngine"
                       FontSize="10"
                       HorizontalOptions="Center"
                       TextColor="#80FFFFFF"
                       Margin="0,8,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
